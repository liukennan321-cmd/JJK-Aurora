			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_SCOUT_EXTRA_ATTACK" level="5" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_SCOUT_EAGLE_EYES" level="5" />
