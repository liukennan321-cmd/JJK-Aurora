			<div element="ID_JJK_CLASS_FEATURE_SCOUT_EAGLE_EYES" />
			<div element="ID_JJK_CLASS_FEATURE_SCOUT_EVASION" />
			<div element="ID_JJK_CLASS_FEATURE_SCOUT_TACTICAL_RETREAT" />
			<div element="ID_JJK_CLASS_FEATURE_SCOUT_SIXTH_SENSE" />
			<div element="ID_JJK_CLASS_FEATURE_SCOUT_SWIFT_DODGE" />
