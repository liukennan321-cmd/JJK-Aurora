	<element name="Tactical Retreat" type="Class Feature" source="JJK" id="ID_JJK_CLASS_FEATURE_SCOUT_TACTICAL_RETREAT">
		<requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_SCOUT_TACTICAL_RETREAT</requirements>
		<description>
			<p>At 10th level, if an opponent moves within 5ft of you, you can move up to your movement speed as a reaction.</p>
			<p class="indent">When you reach 15th level, you can move up to twice your speed.</p>
		</description>
		<sheet action="Reaction">
			<description level="10">If an opponent moves within 5ft of you, you can move up to {speed} ft.</description>
			<description level="15">If an opponent moves within 5ft of you, you can move up to {sc:tr:speed:calculation} ft.</description>
		</sheet>
		<rules>
			<stat name="sc:tr:speed" value="speed" />
			<stat name="sc:tr:speed:calculation" value="sc:tr:speed:double" />
		</rules>
	</element>
	<element name="Sixth Sense" type="Class Feature" source="JJK" id="ID_JJK_CLASS_FEATURE_SCOUT_SIXTH_SENSE">
		<requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_SCOUT_SIXTH_SENSE</requirements>
		<description>
			<p>Beginning at 14th level, you gain advantage on Dexterity saving throws and blindsight out to 30 feet.</p>
		</description>
		<sheet>
			<description>You gain advantage on Dexterity saving throws.</description>
		</sheet>
		<rules>
			<grant type="Vision" id="ID_VISION_BLINDSIGHT" />
			<stat name="blindsight:range" value="30" bonus="base" />
		</rules>
	</element>
	<element name="Swift Dodge" type="Class Feature" source="JJK" id="ID_JJK_CLASS_FEATURE_SCOUT_SWIFT_DODGE">
		<requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_SCOUT_SWIFT_DODGE</requirements>
		<description>
			<p>Starting at 17th level, when an attacker that you can see hits you with an attack, you can use your reaction to ignore the attack's damage against you. You can use this feature a number of times equal to half your proficiency bonus (rounded up) per long rest.</p>
		</description>
		<sheet action="Reaction" usage="{{proficiency:half:up}}/Long Rest">
			<description>When an attacker that you can see hits you with an attack, you can ignore the attack's damage against you.</description>
		</sheet>
	</element>
	<element name="Unfathomable Speed" type="Class Feature" source="JJK" id="ID_JJK_CLASS_FEATURE_SCOUT_UNFATHOMABLE_SPEED">
		<requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_SCOUT_UNFATHOMABLE_SPEED</requirements>
		<description>
			<p>Beginning at 20th level, your speed is faster than anyone can track. Your movement becomes instant and cannot provoke opportunity attacks.</p>
		</description>
		<sheet>
			<description>Your movement becomes instant and cannot provoke opportunity attacks.</description>
		</sheet>
	</element>

