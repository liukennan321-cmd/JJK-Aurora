		</description>
		<sheet display="false">
			<description>You walk surprisingly fast</description>
		</sheet>
		<setters>
			<set name="short">You walk surprisingly fast</set>
			<set name="hd">d8</set>
		</setters>
		<rules>
			<grant type="Proficiency" id="ID_PROFICIENCY_ARMOR_PROFICIENCY_LIGHT_ARMOR" requirements="!ID_JJK_MULTICLASS_SCOUT"/>
			<grant type="Proficiency" id="ID_PROFICIENCY_WEAPON_PROFICIENCY_SIMPLE_WEAPONS" requirements="!ID_JJK_MULTICLASS_SCOUT" />
			<grant type="Proficiency" id="ID_PROFICIENCY_WEAPON_PROFICIENCY_LONGSWORD" requirements="!ID_JJK_MULTICLASS_SCOUT" />
			<grant type="Proficiency" id="ID_PROFICIENCY_WEAPON_PROFICIENCY_RAPIER" requirements="!ID_JJK_MULTICLASS_SCOUT" />
			<grant type="Proficiency" id="ID_PROFICIENCY_WEAPON_PROFICIENCY_SHORTSWORD" requirements="!ID_JJK_MULTICLASS_SCOUT" />
			<grant type="Proficiency" id="ID_PROFICIENCY_SAVINGTHROW_DEXTERITY" requirements="!ID_JJK_MULTICLASS_SCOUT" />
			<grant type="Proficiency" id="ID_PROFICIENCY_SAVINGTHROW_WISDOM" requirements="!ID_JJK_MULTICLASS_SCOUT" />
			<select type="Proficiency" name="Skill Proficiency (Scout)" supports="ID_PROFICIENCY_SKILL_ANIMAL_HANDLING|ID_PROFICIENCY_SKILL_ATHLETICS|ID_PROFICIENCY_SKILL_INTIMIDATION|ID_PROFICIENCY_SKILL_ACROBATICS|ID_PROFICIENCY_SKILL_PERCEPTION|ID_PROFICIENCY_SKILL_SURVIVAL|ID_PROFICIENCY_SKILL_INSIGHT|ID_PROFICIENCY_SKILL_HISTORY" number="2" requirements="!ID_JJK_MULTICLASS_SCOUT" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_SCOUT_CURSED_ENERGY" level="1" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_SCOUT_INNATE_TECHNIQUE" level="1" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_SCOUT_QUICK_STRIKES" level="1" />
			<grant type="Class Feature" id="ID_JJK_CLASS_FEATURE_SCOUT_UNPARALLELED_MOVEMENT" level="1" />
