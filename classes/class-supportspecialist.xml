			<description>Stuck in the infirmary</description>
		</sheet>
		<setters>
			<set name="short">Stuck in the infirmary</set>
			<set name="hd">d6</set>
		</setters>
		<rules>
			<grant type="Proficiency" id="ID_PROFICIENCY_WEAPON_PROFICIENCY_DAGGER" requirements="!ID_JJK_MULTICLASS_SUPPORT_SPECIALIST" />
