<?xml version="1.0" encoding="utf-8" ?>
<elements>
	<info>
		<name>Human</name>
		<description></description>
		<author url="https://docs.google.com/document/d/1rxBzDsWgUR3gqeDADvCE5Zo1obYoBnwdNZXxmQdheP0/edit?tab=t.0#heading=h.ctlbc6irsjfj">JJK</author>
		<update version="5.4">
			<file name="race-human.xml" url="https://raw.githubusercontent.com/VortexTechK/JJK-Aurora/refs/heads/main/races/race-human.xml" />
		</update>
	</info>

	<element name="Human" type="Race" source="JJK" id="ID_RACE_JJK_HUMAN">
		<description>
			<h4>HUMAN TRAITS</h4>
			<p> While many humans vary in shape and size, your human character will have these traits.</p>
			<p>
				<span class="feature">Ability Score Increase.</span>One ability score of your choice increases by 2 and other ability scores increase by 1.<br />
				<span class="feature">Age.</span>Humans reach adulthood in their late teens and live less than a century.<br />
				<span class="feature">Alignment.</span>There is no clear alignment that is consistent among all humans. Just about any alignment can be justified.<br />
				<span class="feature">Size.</span>Humans in the Jujutsu Kaisen world are typically 5-6 feet tall. Some can rest far outside this range, but your size will count as medium.<br />
				<span class="feature">Speed.</span>Your base walking speed is 30 feet.<br />
				<span class="feature">Languages.</span>You can speak, read, and write Common.<br />
			</p>
		</description>
		<sheet display="false" />
		<setters>
			<set name="names" type="male">Yuji, Megumi, Satoru, Suguru, Kento, Toge, Yuta, Aoi, Kokichi, Noritoshi, Takuma, Atsuya, Masamichi, Naobito, Naoya, Jin, Wasuke, Hiromi, Takaba, Ryu, Hajime, Toji</set>
			<set name="names" type="female">Nobara, Maki, Mai, Mei, Utahime, Shoko, Kasumi, Yuki, Rika, Akari, Nagi, Misato</set>
			<set name="names" type="surname">Itadori, Fushiguro, Kugisaki, Gojo, Geto, Nanami, Zenin, Inumaki, Okkotsu, Todo, Nishimiya, Iori, Ieiri, Muta, Miwa, Kamo, Ino, Kusakabe, Yaga, Higuruma, Takaba, Ishigori, Kashimo</set>
			<set name="names-format">{{name}} {{surname}}</set>
			<set name="height" modifier="2d10">5'8"</set>
			<set name="weight" modifier="2d4">110 lb.</set>
		</setters>
		<rules>
			<stat name="strength" value="1" requirements="!(ID_RACE_VARIANT_JJK_JUJUTSU_SORCERER||ID_RACE_VARIANT_JJK_SUPERHUMAN||ID_INTERNAL_GRANTS_DRAGONMARK||ID_WOTC_WGTE_GRANTS_DARKMARKED)" />
			<stat name="dexterity" value="1" requirements="!(ID_RACE_VARIANT_JJK_JUJUTSU_SORCERER||ID_RACE_VARIANT_JJK_SUPERHUMAN||ID_INTERNAL_GRANTS_DRAGONMARK||ID_WOTC_WGTE_GRANTS_DARKMARKED)" />
			<stat name="constitution" value="1" requirements="!(ID_RACE_VARIANT_JJK_JUJUTSU_SORCERER||ID_RACE_VARIANT_JJK_SUPERHUMAN||ID_INTERNAL_GRANTS_DRAGONMARK||ID_WOTC_WGTE_GRANTS_DARKMARKED)" />
			<stat name="intelligence" value="1" requirements="!(ID_RACE_VARIANT_JJK_JUJUTSU_SORCERER||ID_RACE_VARIANT_JJK_SUPERHUMAN||ID_INTERNAL_GRANTS_DRAGONMARK||ID_WOTC_WGTE_GRANTS_DARKMARKED)" />
			<stat name="wisdom" value="1" requirements="!(ID_RACE_VARIANT_JJK_JUJUTSU_SORCERER||ID_RACE_VARIANT_JJK_SUPERHUMAN||ID_INTERNAL_GRANTS_DRAGONMARK||ID_WOTC_WGTE_GRANTS_DARKMARKED)" />
			<stat name="charisma" value="1" requirements="!(ID_RACE_VARIANT_JJK_JUJUTSU_SORCERER||ID_RACE_VARIANT_JJK_SUPERHUMAN||ID_INTERNAL_GRANTS_DRAGONMARK||ID_WOTC_WGTE_GRANTS_DARKMARKED)" />
			<select type="Ability Score Improvement" name="Ability Score Increase +1 (Human)" supports="Custom Ability Score Increase 1" number="1" requirements="!(ID_RACE_VARIANT_JJK_JUJUTSU_SORCERER||ID_RACE_VARIANT_JJK_SUPERHUMAN||ID_INTERNAL_GRANTS_DRAGONMARK||ID_WOTC_WGTE_GRANTS_DARKMARKED)"/>

			<grant type="Size" id="ID_SIZE_MEDIUM" requirements="!ID_RACE_VARIANT_JJK_SUPERHUMAN" />
			<stat name="innate speed" value="30" bonus="base" />
			<grant type="Language" id="ID_LANGUAGE_COMMON" requirements="!ID_WOTC_TCOE_OPTION_CUSTOMIZED_LANGUAGE" />
			<select type="Language" name="Customized Language" supports="Custom Race Language" requirements="ID_WOTC_TCOE_OPTION_CUSTOMIZED_LANGUAGE" />
			<select type="Race Variant" name="JJK Human Variant" supports="JJK Human Variant" optional="true" />
		</rules>
	</element>
	<!-- ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI -->

	<!-- Human Variants -->
	<element name="Jujutsu Sorcerer" type="Race Variant" source="JJK" id="ID_RACE_VARIANT_JJK_JUJUTSU_SORCERER">
		<supports>JJK Human Variant</supports>
		<requirements>ID_INTERNAL_OPTION_ALLOW_FEATS</requirements>
		<description>
			<p>You are part of a family of sorcerers or have been involved from a young age, you gain the following:</p>
			<p>
				<span class="feature">Ability Score Increase.</span>One ability score of your choice increases by 2 and another by 1.<br />
				<span class="feature">Proficiencies.</span>You gain proficiency in martial weapons.<br />
				<span class="feature">Trained Cursed Energy.</span>You gain a Cursed Energy feat.<br />
			</p>
		</description>
		<sheet alt="Human" display="false"/>
		<rules>
			<select type="Ability Score Improvement" name="Ability Score Increase +2 (Jujutsu Sorcerer)" supports="Custom Ability Score Increase 2" number="1" />
			<select type="Ability Score Improvement" name="Ability Score Increase +1 (Jujutsu Sorcerer)" supports="Custom Ability Score Increase 1" number="1" />
			<grant type="Proficiency" id="ID_PROFICIENCY_WEAPON_PROFICIENCY_MARTIAL_WEAPONS" />
			<select type="Feat" name="Cursed Energy Feat (Jujutsu Sorcerer)" />
		</rules>
	</element>
	<element name="Superhuman" type="Race Variant" source="JJK" id="ID_RACE_VARIANT_JJK_SUPERHUMAN">
		<supports>JJK Human Variant</supports>
		<description>
			<p>Very rarely, some humans may be astonishingly stronger than most others in the world, sometimes vastly stronger than the average human. If your human character happens to fall under this category, you can choose to replace the standard Human Ability Score Increase with these traits instead:</p>
			<p>
				<span class="feature">Ability Score Increase.</span>You increase either your Strength, Dexterity, or Constitution score by 2 and the others by 1.<br />
				<span class="feature">Natural Athlete.</span>You have proficiency in the Athletics skill, if you already have proficiency, you instead gain Expertise.<br />
				<span class="feature">Record Breaker.</span>Your jumping distance is doubled.<br />
				<span class="feature">Uncanny Endurance.</span>You can focus on occasionally shrugging off injury. When you take damage, you can use your reaction to roll a d12. Add your Constitution modifier to the number rolled, and reduce the damage by that total. After you use this trait, you can’t use it again until you finish a short or long rest.<br />
				<span class="feature">Powerful Build.</span>You count as one size larger when determining your carrying capacity and the weight you can push, drag, or lift.<br />
				<span class="feature">Speed.</span>Your movement speed is 35 feet.<br />
			</p>
		</description>
		<sheet alt="Human" display="false"/>
		<rules>
			<select type="Ability Score Improvement" name="Superhuman Ability Score Increase" supports="Superhuman ASI Choice" number="1" requirements="!ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI" />
			<select type="Ability Score Improvement" name="Custom Ability Score Improvement +2 (Superhuman)" supports="Custom Ability Score Increase 2" requirements="ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI" number="1" />
			<select type="Ability Score Improvement" name="Custom Ability Score Improvement +1 (Superhuman)" supports="Custom Ability Score Increase 1" requirements="ID_WOTC_TCOE_OPTION_CUSTOMIZED_ASI" number="2"/>
			<grant type="Proficiency" id="ID_INTERNAL_GRANTS_PROFICIENCY_SKILL_OR_DOUBLE_ATHLETICS" />
			<stat name="innate speed" value="35" bonus="base"/>
			<grant type="Size" id="ID_SIZE_LARGE" />
			<grant type="Racial Trait" id="ID_JJK_FEATURE_UNCANNY_ENDURANCE" />
			<grant type="Racial Trait" id="ID_JJK_FEATURE_RECORD_BREAKER" />
		</rules>
	</element>
	<!-- Superhuman Ability Score Bundles -->
	<element name="Superhuman Strength Focus" type="Ability Score Improvement" source="JJK" id="ID_ASI_JJK_SUPERHUMAN_STR">
		<supports>Superhuman ASI Choice</supports>
		<rules>
			<stat name="strength" value="2" />
			<stat name="dexterity" value="1" />
			<stat name="constitution" value="1" />
		</rules>
	</element>
	<element name="Superhuman Dexterity Focus" type="Ability Score Improvement" source="JJK" id="ID_ASI_JJK_SUPERHUMAN_DEX">
		<supports>Superhuman ASI Choice</supports>
		<rules>
			<stat name="strength" value="1" />
			<stat name="dexterity" value="2" />
			<stat name="constitution" value="1" />
		</rules>
	</element>
	<element name="Superhuman Constitution Focus" type="Ability Score Improvement" source="JJK" id="ID_ASI_JJK_SUPERHUMAN_CON">
		<supports>Superhuman ASI Choice</supports>
		<rules>
			<stat name="strength" value="1" />
			<stat name="dexterity" value="1" />
			<stat name="constitution" value="2" />
		</rules>
	</element>
	<element name="Uncanny Endurance" type="Racial Trait" source="JJK" id="ID_JJK_FEATURE_UNCANNY_ENDURANCE">
		<description>
			<p>When you take damage, you can use your reaction to roll a d12 and add your Constitution modifier, reducing the damage by that total. Once you use this trait, you can’t use it again until you finish a short or long rest.</p>
		</description>
		<sheet action="Reaction" usage="1/Short Rest">
			<description>When you take damage roll a d12 and add {{constitution:modifier}}, reducing the damage by that total</description>
		</sheet>
	</element>
	<element name="Record Breaker" type="Racial Trait" source="JJK" id="ID_JJK_FEATURE_RECORD_BREAKER">
		<description>
			<p>Your jumping distance is doubled.</p>
		</description>
		<sheet>
			<description>Your jumping distance is doubled.</description>
		</sheet>
	</element>
</elements>
